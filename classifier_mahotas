def load_grayscale(path: str) -> np.ndarray:
    """Load image and convert to grayscale."""
    im = cv2.imread(path)
    if im is None:
        raise ValueError(f"Cannot load image: {path}")
    if len(im.shape) == 3:
        gray = cv2.cvtColor(im, cv2.COLOR_BGR2GRAY)
    else:
        gray = im
    return gray


def _color_entropy(channel: np.ndarray, bins: int = 32) -> float:
    """Entropy of a single channel histogram."""
    hist, _ = np.histogram(channel.ravel(), bins=bins, range=(0, 256))
    p = hist / max(hist.sum(), 1)
    p = p[p > 0]
    return float(-np.sum(p * np.log2(p)))


def extract_features(gray: np.ndarray, bgr: Optional[np.ndarray] = None) -> Dict[str, float]:
    """
    Extract features using mahotas and OpenCV for heuristic classification.
    Returns a flat dict of feature name -> value.
    """
    h, w = gray.shape
    if gray.size == 0:
        return {}

    features = {}

    # --- Basic geometry ---
    features["aspect_ratio"] = w / max(h, 1)
    features["area"] = w * h

    # --- Intensity ---
    features["mean_intensity"] = float(np.mean(gray))
    features["std_intensity"] = float(np.std(gray))

    # --- Haralick texture (13 values per direction; we use mean) ---
    try:
        haralick = mh.features.haralick(gray).mean(axis=0)
        for i, name in enumerate([
            "haralick_contrast", "haralick_correlation", "haralick_energy",
            "haralick_homogeneity", "haralick_variance", "haralick_sum_avg",
            "haralick_sum_var", "haralick_sum_entropy", "haralick_entropy",
            "haralick_diff_var", "haralick_diff_entropy", "haralick_info_corr_1",
            "haralick_info_corr_2"
        ]):
            features[name] = float(haralick[i])
    except Exception:
        for i in range(13):
            features[f"haralick_{i}"] = 0.0

    # --- LBP texture ---
    try:
        lbp = mh.features.lbp(gray, radius=1, points=8)
        features["lbp_mean"] = float(np.mean(lbp))
        features["lbp_std"] = float(np.std(lbp))
        features["lbp_entropy"] = float(_entropy(lbp.ravel()))
    except Exception:
        features["lbp_mean"] = features["lbp_std"] = features["lbp_entropy"] = 0.0

    # --- Edge / structure (column-like layout) ---
    edges = cv2.Canny(gray, 50, 150)
    features["edge_density"] = float(np.sum(edges > 0) / max(edges.size, 1))

    # Vertical projection (strong peaks => columns) - heavy smoothing for layout structure
    col_proj = np.sum(edges, axis=0)
    # Kernel: ~1/15 of image width, min 31, max 81 - captures column-level structure
    kernel_size = max(31, min(w // 15, 81))
    kernel_size = kernel_size if kernel_size % 2 == 1 else kernel_size + 1
    col_proj_smooth = np.convolve(col_proj, np.ones(kernel_size) / kernel_size, mode="same")
    # Only count peaks with prominence >= 50% of max AND min distance between peaks
    peak_thresh = np.max(col_proj_smooth) * 0.5
    is_peak = (
        (col_proj_smooth[1:-1] > col_proj_smooth[:-2])
        & (col_proj_smooth[1:-1] > col_proj_smooth[2:])
        & (col_proj_smooth[1:-1] >= peak_thresh)
    )
    peak_idx = np.where(is_peak)[0] + 1  # convert back to original indices
    # Enforce min distance: at least min_dist pixels between peaks
    min_dist = max(kernel_size, w // 8)
    n_peaks = 0
    last_i = -min_dist - 1
    for i in peak_idx:
        if i - last_i >= min_dist:
            n_peaks += 1
            last_i = i
    features["vertical_peaks"] = float(n_peaks)

    # --- Otsu / binarization (text vs non-text) ---
    try:
        thresh = mh.thresholding.otsu(gray)
        binary = (gray > thresh).astype(np.uint8)
        features["white_ratio"] = float(np.mean(binary))
        features["otsu_threshold"] = float(thresh)
    except Exception:
        features["white_ratio"] = 0.5
        features["otsu_threshold"] = 128.0

    # --- Blur (photos often smoother) ---
    lap = cv2.Laplacian(gray, cv2.CV_64F)
    features["laplacian_var"] = float(lap.var())

    # --- Local variance (text = high local variance) ---
    try:
        lbp2 = mh.features.lbp(gray, radius=2, points=8)
        features["local_var_mean"] = float(np.mean(lbp2))
    except Exception:
        features["local_var_mean"] = 0.0

    # --- Color features (discriminative: documents vs natural photos) ---
    if bgr is not None and len(bgr.shape) == 3:
        # Color entropy: photos have high, B&W docs have low
        ce = sum(_color_entropy(bgr[:, :, i]) for i in range(3))
        features["color_entropy"] = float(ce / 3.0)
        # Dominant color count: downsample, bin, count non-empty bins
        small = cv2.resize(bgr, (32, 32), interpolation=cv2.INTER_AREA)
        flat = small.reshape(-1, 3)
        bins = 8
        hist = np.zeros((bins, bins, bins))
        for i in range(len(flat)):
            r, g, b = int(flat[i, 0]), int(flat[i, 1]), int(flat[i, 2])
            ri = min((r * bins) >> 8, bins - 1)
            gi = min((g * bins) >> 8, bins - 1)
            bi = min((b * bins) >> 8, bins - 1)
            hist[ri, gi, bi] += 1
        features["dominant_color_count"] = float(np.sum(hist > 0))
    else:
        features["color_entropy"] = 2.0
        features["dominant_color_count"] = 10.0

    # --- Hough lines (documents have many horizontal/vertical lines) ---
    try:
        lines = cv2.HoughLinesP(edges, 1, np.pi / 180, threshold=80, minLineLength=30, maxLineGap=10)
        n_lines = 0 if lines is None else len(lines)
        h_lines = 0
        if lines is not None:
            for line in lines:
                x1, y1, x2, y2 = line[0]
                angle = np.abs(np.degrees(np.arctan2(y2 - y1, x2 - x1)))
                if angle < 15 or angle > 165:
                    h_lines += 1
        features["hough_line_count"] = float(n_lines)
        features["hough_horizontal_ratio"] = h_lines / max(n_lines, 1)
    except Exception:
        features["hough_line_count"] = 0.0
        features["hough_horizontal_ratio"] = 0.0

    # --- Contour stats (documents: many small blobs; photos: fewer larger regions) ---
    try:
        contours, _ = cv2.findContours(edges, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
        areas = [cv2.contourArea(c) for c in contours if cv2.contourArea(c) > 10]
        features["contour_count"] = float(len(areas))
        features["contour_mean_area"] = float(np.mean(areas)) if areas else 0.0
    except Exception:
        features["contour_count"] = 0.0
        features["contour_mean_area"] = 0.0

    return features


def _entropy(arr: np.ndarray, bins: int = 32) -> float:
    """Simple entropy of histogram."""
    hist, _ = np.histogram(arr, bins=bins, range=(arr.min(), max(arr.max(), arr.min() + 1)))
    p = hist / max(hist.sum(), 1)
    p = p[p > 0]
    return float(-np.sum(p * np.log2(p)))


