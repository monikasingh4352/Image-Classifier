if __name__ == "__main__":
    from collections import defaultdict
    import time
    import csv

    dataset_path = Path(DATASET_DIR)

    if not dataset_path.exists():
        print("Dataset path not found:", DATASET_DIR)
        exit()

    print("\nRunning FULL DATASET EVALUATION")
    print("=" * 70)

    knn_dir = DATASET_DIR if USE_KNN else None

    if USE_KNN:
        print("Using kNN leave-one-out mode")
        build_knn_cache(DATASET_DIR)
    else:
        print("Using prototype mode")

    # Automatically detect categories from folder names
    detected_categories = [
        f.name for f in dataset_path.iterdir() if f.is_dir()
    ]

    print("Detected categories:", detected_categories)

    total = 0
    correct = 0

    per_class_total = defaultdict(int)
    per_class_correct = defaultdict(int)
    per_class_time = defaultdict(list)

    results = []

    for cat in detected_categories:
        cat_dir = dataset_path / cat

        for img_path in cat_dir.iterdir():
            if img_path.suffix.lower() not in (
                ".jpg", ".jpeg", ".png", ".bmp", ".webp", ".gif"
            ):
                continue

            try:
                start = time.time()

                pred, conf, _ = classify_image(
                    str(img_path),
                    verbose=False,
                    knn_data_dir=knn_dir,
                )

                end = time.time()
                elapsed = end - start

                total += 1
                per_class_total[cat] += 1
                per_class_time[cat].append(elapsed)

                if pred == cat:
                    correct += 1
                    per_class_correct[cat] += 1
                    status = "✓"
                else:
                    status = "✗"

                print(f"{status} {cat:15s} -> {pred:15s}  {elapsed:.4f}s  {img_path.name}")

                results.append([
                    img_path.name,
                    cat,
                    pred,
                    conf,
                    elapsed
                ])

            except Exception as e:
                print(f"ERROR processing {img_path}: {e}")

    print("\n" + "=" * 70)
    print(f"Total images: {total}")
    print(f"Overall Accuracy: {correct / max(total,1) * 100:.2f}%")

    print("\nPer-Class Accuracy:")
    for cat in detected_categories:
        acc = per_class_correct[cat] / max(per_class_total[cat], 1)
        avg_time = (
            sum(per_class_time[cat]) / max(len(per_class_time[cat]), 1)
        )
        print(
            f"{cat:15s} | "
            f"Accuracy: {acc*100:6.2f}% | "
            f"Avg Time: {avg_time:.4f}s"
        )

    print("=" * 70)

    # Save detailed results CSV
    with open("evaluation_results.csv", "w", newline="") as f:
        writer = csv.writer(f)
        writer.writerow(["image", "actual", "predicted", "confidence", "time_seconds"])
        writer.writerows(results)

    # Save summary CSV
    with open("evaluation_summary.csv", "w", newline="") as f:
        writer = csv.writer(f)
        writer.writerow(["class", "total", "correct", "accuracy", "avg_time_seconds"])
        for cat in detected_categories:
            acc = per_class_correct[cat] / max(per_class_total[cat], 1)
            avg_time = (
                sum(per_class_time[cat]) / max(len(per_class_time[cat]), 1)
            )
            writer.writerow([
                cat,
                per_class_total[cat],
                per_class_correct[cat],
                acc,
                avg_time
            ])

    print("\nCSV files saved:")
    print(" - evaluation_results.csv")
    print(" - evaluation_summary.csv")
