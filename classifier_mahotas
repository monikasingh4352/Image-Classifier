_FEATURE_WEIGHTS["contour_count"] = 1.3


def _normalize_feature(feat_val: float, key: str) -> float:
    """Normalize feature to ~[0, 1] for distance computation. Uses typical ranges."""
    ranges = {
        "vertical_peaks": (0, 12),
        "edge_density": (0.03, 0.28),
        "laplacian_var": (0, 9000),
        "lbp_entropy": (0.3, 2.5),
        "haralick_entropy": (4, 14),
        "haralick_contrast": (0, 0.35),
        "white_ratio": (0.3, 0.95),
        "aspect_ratio": (0.6, 1.6),
        "std_intensity": (25, 70),
        "color_entropy": (2.0, 8.0),
        "dominant_color_count": (5, 120),
        "hough_line_count": (0, 250),
        "hough_horizontal_ratio": (0, 1.0),
        "contour_count": (10, 300),
        "contour_mean_area": (20, 2000),
    }
    lo, hi = ranges.get(key, (0, 1))
    if lo >= hi:
        return 0.5
    return (feat_val - lo) / (hi - lo)


def classify_heuristic(
    features: Dict[str, float],
    verbose: bool = False,
    knn_data_dir: Optional[str] = None,
    current_path: Optional[str] = None,
) -> Tuple[str, float]:
    """
    Classify by nearest prototype (no training, no sklearn).
    If knn_data_dir is set, use 1-NN on dataset exemplars (leave-one-out if current_path in that dir).
    Returns (category, confidence in [0,1]).
    """
    f = {k: features.get(k, 0.0) for k in _FEATURE_KEYS}

    # k-NN mode: 1-NN on dataset features, exclude current image for leave-one-out
    if knn_data_dir:
        build_knn_cache(knn_data_dir)
        if _KNN_CACHE:
            norm_f = {k: _normalize_feature(f[k], k) for k in _FEATURE_KEYS}
            w = _FEATURE_WEIGHTS
            min_d, best_cat = float("inf"), "document"
            exclude = Path(current_path).resolve() if current_path else None
            for path_str, cat, pf in _KNN_CACHE:
                if exclude and Path(path_str) == exclude:
                    continue
                p_norm = {k: _normalize_feature(pf.get(k, 0.0), k) for k in _FEATURE_KEYS}
                d = sum(w.get(k, 1.0) * abs(norm_f[k] - p_norm[k]) for k in _FEATURE_KEYS)
                if d < min_d:
                    min_d, best_cat = d, cat
            conf = max(0.0, 1.0 - min_d / 22.0)
            return best_cat, conf

    # Rule: haralick_contrast very low + high color = natural photo (smooth gradients)
    if f.get("haralick_contrast", 1) < 0.015 and f.get("dominant_color_count", 0) > 58:
        return "natural_photo", 0.95
    # Rule: document vs natural - low contrast + moderate color + structured lines = document
    if f.get("haralick_contrast", 1) < 0.01 and 30 <= f.get("dominant_color_count", 0) <= 55:
        if 80 <= f.get("hough_line_count", 0) <= 250 and f.get("white_ratio", 0) > 0.4:
            return "document", 0.92
    # Rule: high horizontal lines + column-like peaks = two_columns
    if f.get("hough_horizontal_ratio", 0) > 0.88 and f.get("vertical_peaks", 0) <= 5:
        if f.get("edge_density", 0) > 0.12 and f.get("dominant_color_count", 0) < 25:
            return "two_columns", 0.90
    # Rule: many lines + many contours = multi_column
    if f.get("hough_line_count", 0) > 280 and f.get("contour_count", 0) > 220:
        if f.get("vertical_peaks", 0) >= 5:
            return "multi_column", 0.90

    norm_f = {k: _normalize_feature(v, k) for k, v in f.items()}
    min_dist = float("inf")
    best_cat = "document"
    distances = {}
    for cat in CATEGORIES:
        prototypes = _PROTOTYPES[cat]
        cat_min_d = float("inf")
        best_p_norm = {}
        for p in prototypes:
            p_norm = {k: _normalize_feature(p.get(k, 0.0), k) for k in _FEATURE_KEYS}
            w = _FEATURE_WEIGHTS
            d = sum(w.get(k, 1.0) * abs(norm_f[k] - p_norm[k]) for k in _FEATURE_KEYS)
            if d < cat_min_d:
                cat_min_d = d
                best_p_norm = p_norm
        distances[cat] = (cat_min_d, best_p_norm)
        if cat_min_d < min_dist:
            min_dist = cat_min_d
            best_cat = cat
    # Confidence: inverse of distance, scaled to [0,1]; clamp to avoid div by 0
    max_d = 22.0  # max plausible weighted L1 dist (more features now)
    conf = max(0.0, 1.0 - min_dist / max_d)

    if verbose:
        print("\n" + "=" * 70)
        print("FEATURES (raw)")
        print("-" * 70)
        for k in _FEATURE_KEYS:
            print(f"  {k:25s} = {f[k]:.4f}")
        print("\nFEATURES (normalized to [0,1])")
        print("-" * 70)
        for k in _FEATURE_KEYS:
            print(f"  {k:25s} = {norm_f[k]:.4f}")
        print("\nPROTOTYPES (normalized) vs DISTANCE")
        print("-" * 70)
        for cat in sorted(distances.keys()):
            d, p_norm = distances[cat]
            marker = " <-- BEST" if cat == best_cat else ""
            print(f"\n  [{cat}] weighted L1 distance = {d:.4f}{marker}")
            for k in _FEATURE_KEYS:
                diff = _FEATURE_WEIGHTS.get(k, 1.0) * abs(norm_f[k] - p_norm[k])
                print(f"    {k:22s} img_norm={norm_f[k]:.4f}  proto={p_norm[k]:.4f}  |diff|={diff:.4f}")
        print("\n" + "-" * 70)
        print(f"RESULT: {best_cat}  (confidence={conf:.4f})")
        print("=" * 70)

    return best_cat, conf


# Optional k-NN cache: when data_dir provided, use 1-NN on dataset exemplars for higher accuracy
# Cache stores (path, category, features) for leave-one-out during eval
_KNN_CACHE: Optional[List[Tuple[str, str, Dict[str, float]]]] = None
_KNN_CACHE_DIR: Optional[str] = None


def build_knn_cache(data_dir: str) -> None:
    """Precompute features for all images in data_dir (category/subdir structure). Build _KNN_CACHE."""
    global _KNN_CACHE, _KNN_CACHE_DIR
    if _KNN_CACHE_DIR == data_dir and _KNN_CACHE:
        return
    _KNN_CACHE = []
    _KNN_CACHE_DIR = data_dir
    for cat in CATEGORIES:
        d = Path(data_dir) / cat
        if not d.is_dir():
            continue
        for p in d.iterdir():
            if not p.is_file() or p.suffix.lower() not in (".jpg", ".jpeg", ".png", ".gif", ".webp", ".bmp"):
                continue
            path_str = str(p.resolve())
            try:
                im = cv2.imread(path_str)
                if im is None:
                    continue
                gray = cv2.cvtColor(im, cv2.COLOR_BGR2GRAY) if len(im.shape) == 3 else im
                h, w = gray.shape
                if max(h, w) > 512:
                    s = 512 / max(h, w)
                    gray = cv2.resize(gray, None, fx=s, fy=s)
                    im = cv2.resize(im, None, fx=s, fy=s)
                feats = extract_features(gray, bgr=im if len(im.shape) == 3 else None)
                _KNN_CACHE.append((path_str, cat, feats))
            except Exception:
                pass


def classify_image(
    path: str, verbose: bool = False, knn_data_dir: Optional[str] = None
) -> Tuple[str, float, Dict[str, float]]:
    """
    Load image, extract mahotas-based features, classify heuristically.
    Returns (category, confidence, feature_dict).
    If knn_data_dir is provided, uses 1-NN on that dataset for higher accuracy.
    """
    im = cv2.imread(path)
    if im is None:
        raise ValueError(f"Cannot load image: {path}")
