    max_side = 512
    h, w = gray.shape
    if max(h, w) > max_side:
        scale = max_side / max(h, w)
        gray = cv2.resize(gray, None, fx=scale, fy=scale, interpolation=cv2.INTER_AREA)
        if len(im.shape) == 3:
            im = cv2.resize(im, None, fx=scale, fy=scale, interpolation=cv2.INTER_AREA)
    features = extract_features(gray, bgr=im if len(im.shape) == 3 else None)
    category, confidence = classify_heuristic(
        features, verbose=verbose, knn_data_dir=knn_data_dir, current_path=path
    )
    return category, confidence, features



